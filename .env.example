# ========================================
# CONFIGURACIÓN DE RESEND (Email)
# ========================================
# 
# ⚠️ IMPORTANTE: Esta NO es una API key válida
# Necesitas obtener tu propia API key de Resend
#
# Pasos:
# 1. Ve a https://resend.com y crea una cuenta (gratis)
# 2. Obtén tu API key en: https://resend.com/api-keys
# 3. Copia este archivo a .env y reemplaza el valor de abajo
# 4. Reinicia el servidor
#
# La API key debe empezar con 're_' seguido de caracteres aleatorios
#
RESEND_API_KEY=TU_API_KEY_RESEND_AQUI

# ========================================
# CONFIGURACIÓN DE TWILIO (SMS)
# ========================================
#
# ⚠️ IMPORTANTE: Estas NO son credenciales válidas
# Necesitas obtener tus propias credenciales de Twilio
#
# Pasos:
# 1. Ve a https://www.twilio.com/try-twilio y crea una cuenta
# 2. Verifica tu email y número de teléfono
# 3. Obtén $15 USD de crédito gratis para pruebas
# 4. En el Dashboard de Twilio, copia:
#    - Account SID (empieza con 'AC...')
#    - Auth Token
# 5. Ve a Phone Numbers → Manage → Active numbers
#    - Copia tu número de Twilio (formato: +1234567890)
# 6. Reemplaza los valores de abajo
# 7. Reinicia el servidor
#
# Nota: El plan gratuito requiere verificar los números que recibirán SMS
#
TWILIO_ACCOUNT_SID=TU_ACCOUNT_SID_AQUI
TWILIO_AUTH_TOKEN=TU_AUTH_TOKEN_AQUI
TWILIO_PHONE_NUMBER=TU_NUMERO_TWILIO_AQUI
